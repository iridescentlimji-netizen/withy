# Backend (local development)
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/kid_schedule
DB_USERNAME=kid_schedule
DB_PASSWORD=kid_schedule
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=local-dev-jwt-secret-key-at-least-32-chars
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URIS=http://192.168.45.142:8080/api/v1/auth/kakao/redirect,http://localhost:8080/api/v1/auth/kakao/redirect
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URIS=http://192.168.45.142:8080/api/v1/auth/naver/redirect,http://localhost:8080/api/v1/auth/naver/redirect
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URIS=http://192.168.45.142:8080/api/v1/auth/google/redirect,http://localhost:8080/api/v1/auth/google/redirect

# Mobile (Expo — prefix with EXPO_PUBLIC_ for client access)
# 실기기 테스트: Mac Wi-Fi IP 사용 (ipconfig getifaddr en0)
# 시뮬레이터만 쓸 때: http://localhost:8080
EXPO_PUBLIC_API_URL=http://192.168.45.142:8080
